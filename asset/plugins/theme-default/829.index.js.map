import { useSelector, SummaryPart, SummaryArticle, Link } from 'topwrite';
import { FC, useState, useEffect, useCallback } from 'react';
import style from '../scss/summary.module.scss';
import { BsCaretDownFill } from '@react-icons/all-files/bs/BsCaretDownFill';
import { BsCaretRightFill } from '@react-icons/all-files/bs/BsCaretRightFill';
import classNames from 'classnames';

const Item: FC<{ item: SummaryArticle }> = ({ item }) => {

    const { path: current } = useSelector('file');
    const [open, setOpen] = useState(() => {
        return !!SummaryArticle.findArticle(item, (article: SummaryArticle) => article.getPath() === current);
    });
    const active = current === item.getPath();
    const hasChildren = item.children.length > 0;

    useEffect(() => {
        if (!open && SummaryArticle.findArticle(item, (article: SummaryArticle) => article.getPath() === current)) {
            setOpen(true);
        }
    }, [item, current]);

    const handleSpaceClick = useCallback(() => {
        if (hasChildren) {
            setOpen(!open);
        } else if (!active) {
            // setCurrent(item.ref);
        }
    }, [open, item.getPath(), hasChildren]);

    return <li className={classNames({ [style.open]: open })}>
        <div className={classNames(style.item, {
            [style.active]: active,
            [style.disabled]: !item.getPath(),
        })}>
            <div className={style.whole} />
            <span className={style.space} onClick={handleSpaceClick}>
                {hasChildren && (open ? <BsCaretDownFill size={12} /> : <BsCaretRightFill size={12} />)}
            </span>
            <Link className={style.text} to={item}>
                {item.title}
            </Link>
        </div>
        {hasChildren && <Items items={item.children} />}
    </li>;
};

const Items: FC<{ items: SummaryArticle[] }> = ({ items }) => {
    return <ul>
        {items.map((item, index) => <Item key={`item-${index}`} item={item} />)}
    </ul>;
};

const Part: FC<{ part: SummaryPart }> = ({ part }) => {
    return <div className={style.part}>
        <div className={style.title}>
            {part.title}
        </div>
        <Items items={part.articles} />
    </div>;
};

const Parts: FC<{ parts: SummaryPart[] }> = ({ parts }) => {
    if (parts.length === 1 && !parts[0].title) {
        return <Items items={parts[0].articles} />;
    }

    return <>{parts.map((part, index) => {
        return <Part key={`index-${index}`} part={part} />;
    })}</>;
};

export default function Summary() {
    const { summary } = useSelector('book');
    return <div className={style.summary}>
        <Parts parts={summary.parts} />
    </div>;
}
