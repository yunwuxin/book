import { useEffect } from 'react';
import style from '../scss/body.module.scss';
import Sidebar from '@/components/sidebar';
import { useSelector, history, useArticle } from 'topwrite';
import Document from '@/components/document';
import classNames from 'classnames';

export default function Body() {

    const file = useSelector('file');
    const { summary } = useSelector('book');

    const article = useArticle();

    useEffect(() => {
        if (!article) {
            const firstArticle = summary.getFirstArticle();
            if (firstArticle) {
                history.replace(file.relative(firstArticle.getPath()));
            }
        }
    }, [article]);

    if (!article) {
        return null;
    }

    return <div className={classNames(style.body, style.withSidebar)}>
        <Sidebar />
        <Document article={article} />
    </div>;
}
