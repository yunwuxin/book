import { Link, Markdown, SummaryArticle, useSelector, useIntl } from 'topwrite';
import style from '../scss/main.module.scss';
import { useEffect, useMemo } from 'react';

interface DocumentProps {
    article: SummaryArticle
}

export default function Document({ article }: DocumentProps) {

    const file = useSelector('file');
    const { summary } = useSelector('book');
    const intl = useIntl();

    const prevArticle = useMemo(() => summary.getPrevArticle(article), [summary, article]);
    const nextArticle = useMemo(() => summary.getNextArticle(article), [summary, article]);

    useEffect(() => {
        window.scrollTo(0, 0);
    }, [article]);

    return <div className={style.main}>
        <div className={style.toolbar}>
            <h1>{article.title}</h1>
        </div>
        <Markdown className={style.content}>
            {file.content}
        </Markdown>
        <div className={style.navigation}>
            {prevArticle && <span className={style.prev}>
                {intl.formatMessage({ defaultMessage: '上一篇' })}:<Link to={prevArticle}>{prevArticle.title}</Link>
            </span>}
            {nextArticle && <span className={style.next}>
                {intl.formatMessage({ defaultMessage: '下一篇' })}:<Link to={nextArticle}>{nextArticle.title}</Link>
            </span>}
        </div>
    </div>;
}
